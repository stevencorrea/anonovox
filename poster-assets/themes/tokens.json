{
  "$schema": "anonovox poster theme tokens",
  "themes": {
    "light": {
      "label": "Royal Blue + Creme (default)",
      "use": "On-screen viewing, light slide decks, mock-ups in cream-paper layouts.",
      "color": {
        "bg":            "#faf5f0",
        "surface":       "#ffffff",
        "surface-alt":   "#f5ede6",
        "text-primary":  "#1a1410",
        "text-secondary":"#5a5450",
        "text-tertiary": "#8b8480",
        "accent":        "#2c3e7a",
        "accent-light":  "#4a5fa0",
        "accent-lighter":"#7a8fc4",
        "accent-pale":   "#e8eaf6",
        "border":        "rgba(44, 62, 122, 0.12)",
        "border-light":  "rgba(44, 62, 122, 0.06)",
        "rule":          "#2c3e7a",
        "error":         "#c41e3a",
        "success":       "#2d5016",
        "warning":       "#8b5a00"
      }
    },
    "dark": {
      "label": "Midnight Sapphire",
      "use": "Dark slide backgrounds, hero panels, projector environments.",
      "color": {
        "bg":            "#0f1318",
        "surface":       "#1a1f27",
        "surface-alt":   "#242c38",
        "text-primary":  "#e8e8ed",
        "text-secondary":"#b0b0b8",
        "text-tertiary": "#808088",
        "accent":        "#6b8ee4",
        "accent-light":  "#8ba5f0",
        "accent-lighter":"#a8bef8",
        "accent-pale":   "#1a2a4a",
        "border":        "rgba(107, 142, 228, 0.20)",
        "border-light":  "rgba(107, 142, 228, 0.10)",
        "rule":          "#6b8ee4",
        "error":         "#ff6b7a",
        "success":       "#7fd85f",
        "warning":       "#ffb84d"
      }
    },
    "print": {
      "label": "Capstone Print (28\" x 22\")",
      "use": "Large-format print. Deeper inks, warmer paper, higher contrast — compensates for 4-color CMYK shift on matte stock.",
      "notes": [
        "Background is a slightly warmer cream so the printed paper does not look gray under fluorescent gallery lighting.",
        "Accent is darkened to print as a true royal blue rather than washed periwinkle.",
        "All text is true black for crisp 300 DPI rendering of small captions on a 28\" x 22\" board.",
        "Borders are solid hex (no rgba) so print drivers do not flatten transparency unpredictably."
      ],
      "color": {
        "bg":            "#f7f0e6",
        "surface":       "#ffffff",
        "surface-alt":   "#efe5d6",
        "text-primary":  "#0a0805",
        "text-secondary":"#3d3833",
        "text-tertiary": "#6b6560",
        "accent":        "#1d2d63",
        "accent-light":  "#34488f",
        "accent-lighter":"#6478b3",
        "accent-pale":   "#dde1f2",
        "border":        "#c9bfb0",
        "border-light":  "#e2d9c9",
        "rule":          "#1d2d63",
        "error":         "#9c1224",
        "success":       "#1f3a0e",
        "warning":       "#6b4500"
      },
      "print-specs": {
        "size":         "28in x 22in",
        "bleed":        "0.125in",
        "safe-margin":  "0.5in",
        "dpi":          300,
        "color-mode":   "CMYK",
        "stock":        "matte (vinyl or heavy paper)"
      }
    }
  },
  "type": {
    "display":      "'Prata', 'Cormorant Garamond', serif",
    "body":         "'Inter', 'Instrument Sans', sans-serif",
    "mono":         "'Fira Code', 'Courier New', monospace",
    "scale-poster": {
      "title":      "180pt",
      "subtitle":   "60pt",
      "section-h":  "44pt",
      "body":       "20pt",
      "caption":    "14pt",
      "eyebrow":    "12pt (uppercase, 0.12em tracked)"
    }
  },
  "rules": {
    "vertical-spine": "2px linear gradient (transparent → accent → transparent), 30% opacity — borrowed from index.html .hero::before",
    "eyebrow-bar":    "1px × 24px solid accent, sits left of an uppercase 12pt label",
    "section-rule":   "1px border-light hairline above each section title",
    "card":           "1px solid border-light, 12px radius, optional 3px top accent bar that scales on hover (animation drops in print)"
  }
}
