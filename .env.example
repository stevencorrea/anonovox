# Core app and auth
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/anonovox
BETTER_AUTH_SECRET=replace-with-a-random-secret
BETTER_AUTH_URL=http://localhost:3000
PORT=3000
NODE_ENV=development
ADDITIONAL_TRUSTED_ORIGINS=

# Email and digests
RESEND_API_KEY=
EMAIL_FROM=anonovox <noreply@example.com>

# AI insights
ANTHROPIC_API_KEY=

# Microsoft sign-in and optional Entra SSO
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
ENTRA_ADMIN_ROLE_IDS=
STAFF_EMAIL_DOMAIN=anonovox.com

# Teams integration
# Leave these blank to reuse MICROSOFT_CLIENT_ID and MICROSOFT_CLIENT_SECRET.
TEAMS_APP_ID=
TEAMS_APP_SECRET=

# Slack integration
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Scheduler
ENABLE_IN_PROCESS_SCHEDULER=true
SCHEDULER_SECRET=replace-with-a-separate-scheduler-secret

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
